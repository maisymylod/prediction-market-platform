{
  "name": "prediction-market-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm --filter web build",
    "db:generate": "pnpm --filter @pmp/db generate",
    "db:migrate": "pnpm --filter @pmp/db migrate",
    "db:seed": "pnpm --filter @pmp/db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
