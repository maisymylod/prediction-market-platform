# =============================================================================
# Prediction Market Platform — environment variables
# =============================================================================
# Copy to `.env` and fill in only what you need. The app BOOTS AND RUNS END TO
# END WITH ZERO SECRETS: leave all live flags off and the price simulator drives
# the dashboard on seed + demo data. Never commit your real .env.
# =============================================================================

# --- Core -------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info                       # error | warn | info | debug

# Postgres connection string used by web + worker.
# Host port is 5433 to avoid clashing with a local Postgres on 5432.
# Inside docker-compose the services override this to point at the `db` service.
DATABASE_URL=postgres://pmp:pmp@localhost:5433/pmp

# Credentials used ONLY by the docker-compose `db` service to initialise Postgres.
POSTGRES_USER=pmp
POSTGRES_PASSWORD=pmp
POSTGRES_DB=pmp

# Web app
WEB_PORT=3000
# Public base URL the browser uses for the SSE stream (same-origin by default).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Feature flags ----------------------------------------------------------
# Default posture: simulator ON, both live venues OFF. App needs no real keys.
USE_PRICE_SIMULATOR=true             # emit simulated ticks through the real NOTIFY path
USE_KALSHI_LIVE=false                # connect to Kalshi WS/REST (requires keys below)
USE_POLYMARKET_LIVE=false            # poll Polymarket public price API

# --- Tunables (safe defaults; all validated by Zod at startup) --------------
POLL_INTERVAL_MS=3000                # Polymarket REST poll cadence
RECONCILE_INTERVAL_MS=30000          # full reconciliation cadence (correctness backstop)
STALE_THRESHOLD_MS=10000             # mark a feed STALE after this much silence
DEBOUNCE_MS=250                      # max one risk recompute per this window (browser)
BASIS_THRESHOLD=0.05                 # flag cross-venue basis above this (probability pts)
SIMULATOR_TICK_MS=1000               # simulator emit interval per watched market

# --- Kalshi (only needed when USE_KALSHI_LIVE=true) -------------------------
# Defaults below are the DEMO environment (mock funds). Public market-data
# endpoints need no auth; positions/fills need the API key + RSA private key.
KALSHI_API_BASE=https://demo-api.kalshi.co/trade-api/v2
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
KALSHI_API_KEY_ID=
# Provide the RSA private key by ABSOLUTE PATH (preferred) or inline PEM.
# The file/value is read by the worker only and never sent to the browser.
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PRIVATE_KEY=

# --- Polymarket (only needed when USE_POLYMARKET_LIVE=true) -----------------
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
# Optional: a wallet address whose positions to ingest (read-only, public data).
POLYMARKET_WALLET_ADDRESS=

# --- Anthropic (only needed for the LLM-assisted event matcher) -------------
# When absent, the matcher UI is disabled; seed ships pre-confirmed links so the
# cross-venue view still demos fully.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
